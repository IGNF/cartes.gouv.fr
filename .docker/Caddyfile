# Configuration FrankenPHP / Caddy de cartes.gouv.fr
{
	frankenphp {
		# nombre de threads php maximum pour traiter des requêtes simultanées
		num_threads {$FRANKENPHP_NUM_THREADS:4}

		# Worker mode (désactivé pour le moment)
		# worker /opt/cartesgouvfr-site/public/index.php
		# ajouter runtime/frankenphp-symfony aux dépendances composer
	}

	# TLS terminé par le reverse proxy amont
	auto_https off

	# Conteneur immutable : pas de reload de config, l'endpoint d'admin est inutile
	admin off

	# Logs en texte brut ; level_format upper évite les codes couleur ANSI
	log {
		format console {
			level_format upper
		}
	}

	# Laisser au plus 25 s aux requêtes en cours à l'arrêt (drain infini par défaut)
	grace_period 25s

	# respond (405 TRACE, 404 .ht*) doit passer avant les redirections
	order respond before redir

	# La résolution X-Forwarded-For appartient à Symfony (TRUSTED_PROXIES)
}

:8000 {
	root * /opt/cartesgouvfr-site/public

	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		-Server
		-X-Powered-By
	}

	# Cache long pour les assets Vite (noms de fichiers hashés)
	@build path /build/*
	header @build Cache-Control "public, max-age=31536000, immutable"

	# Statiques à nom fixe : cache modéré avec revalidation (ETag/Last-Modified
	# fournis par Caddy) ; le matcher `file` évite de cacher un fallback SPA 404
	@static {
		path /favicon/* /bundles/* /favicon.ico /robots.txt
		file
	}
	header @static Cache-Control "public, max-age=86400, must-revalidate"

	# Équivalent du TraceEnable Off d'Apache
	@trace method TRACE
	respond @trace 405

	# Ne jamais servir les fichiers .ht* (public/.htaccess reste dans l'image pour
	# XAMPP) : réécrire vers un chemin inexistant pour que la requête tombe dans le
	# front controller - l'utilisateur voit la page 404 React, comme tout chemin inconnu
	@hidden path */.ht*
	rewrite @hidden /__fichier-cache__

	# Redirections héritées (ex-RedirectMatch du vhost Apache), query string préservée
	redir / /explorer-les-cartes{?query} 301
	@faq path /faq /faq/
	redir @faq /aide/fr{?query} 301
	@apropos path /a-propos /a-propos/
	redir @apropos /decouvrir{?query} 301
	@nousecrire path /nous-ecrire /nous-ecrire/
	redir @nousecrire /aide/fr/nous-ecrire{?query} 301
	@offre path /offre /offre/
	redir @offre /offres{?query} 301

	# Canonicalisation /index.php → URL propre (parité avec public/.htaccess)
	@indexphp path_regexp idx ^/index\.php(?:/(.*))?$
	redir @indexphp /{re.idx.1}{?query} 301

	# Ne pas logger les probes de santé (équivalent du SetEnvIf dontlog)
	@health path_regexp ^/tableau-de-bord/health/?$
	log_skip @health

	# Access log en texte brut ; filter supprime les champs et headers sans intérêt
	# (blocklist : un nouveau header non listé réapparaîtra dans les logs).
	# Conservés volontairement : Referer, User-Agent, X-Forwarded-For (parité avec
	# l'ex-LogFormat Apache), X-Request-Id, host/method/uri/proto, status, size, duration.
	log {
		output stdout
		format filter {
			wrap console {
				level_format upper
			}
			fields {
				# champs hors headers
				request>remote_port delete
				bytes_read delete
				user_id delete
				resp_headers delete
				# credentials (déjà REDACTED par Caddy, supprimés entièrement)
				request>headers>Cookie delete
				request>headers>Authorization delete
				# négociation / cache
				request>headers>Accept delete
				request>headers>Accept-Encoding delete
				request>headers>Accept-Language delete
				request>headers>Cache-Control delete
				request>headers>Pragma delete
				request>headers>If-None-Match delete
				request>headers>If-Modified-Since delete
				request>headers>Connection delete
				request>headers>Keep-Alive delete
				request>headers>Priority delete
				request>headers>Upgrade-Insecure-Requests delete
				# fetch metadata / client hints / privacy
				request>headers>Sec-Fetch-Site delete
				request>headers>Sec-Fetch-Mode delete
				request>headers>Sec-Fetch-Dest delete
				request>headers>Sec-Fetch-User delete
				request>headers>Sec-Ch-Ua delete
				request>headers>Sec-Ch-Ua-Mobile delete
				request>headers>Sec-Ch-Ua-Platform delete
				request>headers>Sec-Gpc delete
				request>headers>Dnt delete
				# ajoutés par l'ingress (redondants : XFF suffit)
				request>headers>X-Real-Ip delete
				request>headers>X-Scheme delete
				request>headers>X-Forwarded-Proto delete
				request>headers>X-Forwarded-Host delete
				request>headers>X-Forwarded-Port delete
				request>headers>X-Forwarded-Scheme delete
				# toujours "XMLHttpRequest" (injecté par jsonFetch)
				request>headers>X-Requested-With delete
			}
		}
	}

	# Front controller Symfony : fichiers existants servis tels quels,
	# tout le reste vers public/index.php
	php_server
}
